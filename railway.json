{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "php": "8.2",
      "node": "20",
      "packages": ["imagemagick"]
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "command": "php artisan serve --host=0.0.0.0 --port=$PORT"
  }
}
